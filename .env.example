# Flask App Configurations
SECRET_KEY=your_secret_key_here

# PostgreSQL Database URL
# Local format:  postgresql://user:password@localhost:5432/dbname
# Neon format:   postgresql://user:password@host.neon.tech/dbname?sslmode=require
# NOTE: If your password contains special characters like @ use URL encoding:
#       @ becomes %40  (e.g. My@Pass becomes My%40Pass)
DATABASE_URL=your_database_url_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
